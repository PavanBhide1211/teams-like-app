{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Cowork Chat",
  "version": "0.1.0",
  "identifier": "eu.cowork.chat",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Cowork Chat",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "decorations": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: https:; connect-src 'self' http://localhost:8000 ws://localhost:8000; style-src 'self' 'unsafe-inline'; script-src 'self'",
      "devCsp": null,
      "pattern": { "use": "brownfield" }
    },
    "trayIcon": {
      "id": "cowork-tray",
      "iconPath": "icons/icon.png",
      "tooltip": "Cowork Chat",
      "menuOnLeftClick": false
    }
  },
  "bundle": {
    "active": true,
    "category": "SocialNetworking",
    "icon": ["icons/icon.png"],
    "shortDescription": "Lean Teams-like chat",
    "longDescription": "EU AI Act-conscious chat client. Memory- and CPU-efficient. Tauri 2 + Rust + React.",
    "resources": []
  },
  "plugins": {
    "notification": {}
  }
}
